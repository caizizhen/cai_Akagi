{
  "productName": "Akagi",
  "identifier": "com.akagi.akagi",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "./frontend"
    },
    "beforeBuildCommand": {
      "script": "npm ci && npm run build",
      "cwd": "./frontend"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Akagi",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "runtime/**/*"
    ]
  }
}
