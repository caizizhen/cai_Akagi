{
  "productName": "Akagi",
  "version": "0.1.0",
  "identifier": "com.akagi.app",
  "build": {
    "frontendDist": "./frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "./frontend"
    },
    "beforeBuildCommand": {
      "script": "npm ci && npm run build",
      "cwd": "./frontend"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Akagi",
        "width": 1560,
        "height": 980,
        "minWidth": 1280,
        "minHeight": 820
      }
    ]
  }
}
